{
  "application": {
    "name": "Hệ Thống Quản Lý Gia Phả Họ Cao Ninh Bình",
    "version": "2.1.0",
    "theme": "Imperial Heritage",
    "framework": "React 18 + Vite + Tailwind CSS",
    "animationLibrary": "motion/react",
    "excelParserLibrary": "xlsx"
  },
  "designSystem": {
    "colors": {
      "primary": {
        "hex": "#064e3b",
        "tailwind": "emerald-950",
        "usage": "Header, Sidebar, Main buttons"
      },
      "secondary": {
        "hex": "#0f766e",
        "tailwind": "teal-700",
        "usage": "Muted actions, highlights"
      },
      "accent": {
        "hex": "#fef3c7",
        "tailwind": "amber-100",
        "usage": "Special royal titles, admin badges"
      },
      "background": {
        "hex": "#fafaf9",
        "tailwind": "stone-50",
        "usage": "Main content body background"
      },
      "border": {
        "hex": "#e7e5e4",
        "tailwind": "stone-200",
        "usage": "Grid separators, card borders"
      },
      "genderMale": {
        "hex": "#1e3a8a",
        "tailwind": "blue-900",
        "backgroundHex": "#eff6ff",
        "tailwindBg": "blue-50",
        "label": "Nghị"
      },
      "genderFemale": {
        "hex": "#9d174d",
        "tailwind": "pink-800",
        "backgroundHex": "#fdf2f8",
        "tailwindBg": "pink-50",
        "label": "Nữ"
      },
      "deceased": {
        "hex": "#991b1b",
        "tailwind": "red-800",
        "backgroundHex": "#fef2f2",
        "tailwindBg": "red-50",
        "label": "Đã quy tiên"
      }
    },
    "typography": {
      "serif": {
        "fontFamily": "Playfair Display, Georgia, serif",
        "class": "font-serif",
        "usage": "Ancestor names, headings, monumental titles"
      },
      "sans": {
        "fontFamily": "Inter, system-ui, sans-serif",
        "class": "font-sans",
        "usage": "General UI, cards, layout, tabular content"
      },
      "mono": {
        "fontFamily": "Fira Code, JetBrains Mono, monospace",
        "class": "font-mono",
        "usage": "IDs, Phone numbers, Lunar years, calculations"
      }
    },
    "transitions": {
      "default": "all 200ms ease-in-out",
      "mobileOverlay": "lg:hidden fixed inset-0 bg-black/60 z-35 backdrop-blur-xs"
    }
  },
  "rolesAndPermissions": {
    "system": "Multi-role concurrent assignment (Song hành đa chức sự)",
    "availableRoles": [
      {
        "id": "admin",
        "label": "👑 Chánh Tổng Quản",
        "description": "Toàn quyền quản trị hệ thống, cấp đặc sắc và phân vai trò hoạt động."
      },
      {
        "id": "treasurer",
        "label": "💰 Thủ Quỹ Gia Tộc",
        "description": "Quản lý dòng tiền, ghi nhận các quỹ hiển lạp, minh bạch hóa thu chi."
      },
      {
        "id": "writer",
        "label": "✍️ Sử Biên Ký",
        "description": "Biên soạn gia chí, ghi chép tiểu sử tông chi và biên sử cổ vật dòng họ."
      },
      {
        "id": "secretary",
        "label": "📝 Thư Ký Họ",
        "description": "Phụ trách truyền tin Zalo, quản lý dữ liệu chiến dịch và duyệt đinh viên."
      },
      {
        "id": "user",
        "label": "👥 Đinh Viên Tuyên Đức / Hương Đinh",
        "description": "Thành viên gia đình, truy cập đọc hiểu phả hệ và gửi kiến nghị."
      }
    ]
  },
